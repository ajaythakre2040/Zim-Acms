{
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    
    /* FIX 1: Modern module resolution for tools like Vite */
    "moduleResolution": "Bundler", 
    
    /* FIX 2: BaseUrl hatakar direct paths use karein */
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    },
    
    "types": ["node", "vite/client", "mssql"]
  }
}